# .gitignore
# Covers C# and common tools used in this project.

# Build outputs
bin/
obj/
artifacts/

# .NET
*.user
*.suo
.vs/
*.slnx.user

# Visual Studio Code
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains Rider
.idea/
*.sln.iml

# Test results
TestResults/
*.trx

# Code coverage
coverage/
*.coverage
*.coveragexml
*.opencover.xml

# Python virtual environment
.venv/

# Node
node_modules/
package-lock.json

# Generated compliance documents (build outputs — never committed)
**/generated/

# Agent logs
.agent-logs/
AGENT_REPORT_*.md

# VersionMark captures (generated during CI/CD)
versionmark-*.json

# Temporary files
*.tmp
*.bak
*~

# OS
.DS_Store
Thumbs.db
